# ========================================
# 功能开关配置 (Feature Flags)
# ========================================

# 微博用户管理 + 爬虫模块总开关（控制微博用户管理、爬虫任务、Playwright 初始化）
# - true:  启用微博用户管理、爬虫任务管理 + 对应后端 API
# - false: 屏蔽微博用户管理 + 爬虫相关功能（情报管理 + 信息提取不受影响）
FEATURE_WEIBO_USERS=true

# AI 助写功能（LLM 对接）
# - true:  启用 AI 生成、润色等 LLM 相关能力
# - false: 关闭 LLM 相关功能入口
FEATURE_LLM=true

# ========================================
# MongoDB 配置
# ========================================
# 切换环境：local = 本地数据库，production = 线上数据库
MONGODB_ENV=local

# 本地环境
LOCAL_MONGODB_HOST=localhost
LOCAL_MONGODB_PORT=27017
LOCAL_MONGODB_DB=guozi_cai
# LOCAL_MONGODB_USER=
# LOCAL_MONGODB_PASSWORD=

# 线上环境
PROD_MONGODB_HOST=172.16.8.53
PROD_MONGODB_PORT=27017
PROD_MONGODB_DB=guozi_cai
PROD_MONGODB_USER=hentre
PROD_MONGODB_PASSWORD=Hentre2026!
